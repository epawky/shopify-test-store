<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    {%- comment -%} Google Fonts — Cormorant Garamond & DM Sans {%- endcomment -%}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=DM+Sans:wght@300;400&display=swap" rel="stylesheet">

    {%- comment -%} Aurea design tokens {%- endcomment -%}
    {{ 'aurea-tokens.css' | asset_url | stylesheet_tag }}

    {%- comment -%} Inlined CSS Variables {%- endcomment -%}
    {% render 'css-variables' %}

    {%- comment -%} Critical CSS {%- endcomment -%}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}

    {%- comment -%} Social, title, etc. {%- endcomment -%}
    {% render 'meta-tags' %}

    {{ content_for_header }}
  </head>

  <body>
    {% sections 'header-group' %}

    {{ content_for_layout }}

    {% sections 'footer-group' %}

    {%- comment -%} Storefront API config {%- endcomment -%}
    <script>
      window.Aurea = {
        storefrontToken: '37fa638563f9439d3c55aa5bb28327bc',
        shopDomain: {{ request.host | json }},
        rootUrl: {{ routes.root_url | json }},
        cartUrl: {{ routes.cart_url | json }},
        routes: {
          cart_add_url: '{{ routes.cart_add_url }}',
          cart_change_url: '{{ routes.cart_change_url }}',
          cart_update_url: '{{ routes.cart_update_url }}',
          cart_url: '{{ routes.cart_url }}'
        }
      };
    </script>

    <script src="{{ 'aurea-animations.js' | asset_url }}" defer></script>
  </body>
</html>
