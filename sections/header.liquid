{%- comment -%} Announcement Bar {%- endcomment -%}
<div class="announcement-bar full-width">
  <p>{{ section.settings.announcement_text }}</p>
</div>

{%- comment -%} Header / Navigation {%- endcomment -%}
<header class="aurea-header full-width">
  <nav class="aurea-header__inner">
    <div class="aurea-header__nav">
      <a href="/collections" class="aurea-header__link">Collections</a>
      <a href="/pages/our-story" class="aurea-header__link">Our Story</a>
      <a href="/pages/provenance" class="aurea-header__link">Provenance</a>
      <a href="/blogs/journal" class="aurea-header__link">Journal</a>
    </div>

    <a href="{{ routes.root_url }}" class="aurea-header__logo">Aurea</a>

    <div class="aurea-header__icons">
      <a href="{{ routes.search_url }}" class="aurea-header__icon aurea-header__icon--search" aria-label="Search">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </a>

      {% if shop.customer_accounts_enabled %}
        <a href="{{ routes.account_url }}" class="aurea-header__icon" aria-label="Account">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
        </a>
      {% endif %}

      <a href="{{ routes.cart_url }}" class="aurea-header__icon aurea-header__icon--cart" aria-label="Cart">
        {% if cart.item_count > 0 %}
          <span class="aurea-header__cart-count">{{ cart.item_count }}</span>
        {% endif %}
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
      </a>
    </div>
  </nav>
</header>

{% stylesheet %}
  /* ── Announcement Bar ── */
  .announcement-bar {
    background: #111714;
    text-align: center;
    padding: 10px 24px;
  }
  .announcement-bar p {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 10px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: #C5A96B;
    margin: 0;
  }

  /* ── Header ── */
  .aurea-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(26, 31, 28, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(197, 169, 107, 0.18);
    transition: background 0.4s ease, border-color 0.4s ease;
  }
  .aurea-header.header--scrolled {
    background: rgba(26, 31, 28, 0.97);
    border-bottom-color: rgba(197, 169, 107, 0.28);
  }

  .aurea-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    padding: 0 48px;
  }

  /* ── Logo ── */
  .aurea-header__logo {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 28px;
    font-weight: 300;
    letter-spacing: 0.12em;
    color: #F5F0E8;
    text-decoration: none;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  /* ── Nav Links ── */
  .aurea-header__nav {
    display: flex;
    gap: 28px;
  }
  .aurea-header__link {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 10px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: rgba(245, 240, 232, 0.45);
    text-decoration: none;
    transition: color 0.3s ease;
  }
  .aurea-header__link:hover {
    color: #C5A96B;
  }

  /* ── Icons ── */
  .aurea-header__icons {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .aurea-header__icon {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(245, 240, 232, 0.6);
    text-decoration: none;
    transition: color 0.3s ease;
  }
  .aurea-header__icon--search {
    color: #C5A96B;
  }
  .aurea-header__icon:hover {
    color: #C5A96B;
  }
  .aurea-header__cart-count {
    position: absolute;
    top: -6px;
    right: -8px;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 9px;
    font-weight: 400;
    color: #111714;
    background: #C5A96B;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .aurea-header__inner { padding: 0 20px; }
    .aurea-header__nav { display: none; }
    .aurea-header__logo {
      position: static;
      transform: none;
      font-size: 24px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "Complimentary engraving on all fragrances above 100ml  \u00b7  New arrivals every Thursday"
    }
  ]
}
{% endschema %}
