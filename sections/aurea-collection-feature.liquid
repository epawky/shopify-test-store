{%- comment -%} AUREA PARIS — Homepage Collection Feature {%- endcomment -%}

<section class="aurea-collection-feature full-width">
  <div class="aurea-collection-feature__header">
    <div class="aurea-collection-feature__rule"></div>
    <p class="aurea-collection-feature__overline">{{ section.settings.overline }}</p>
    <h2 class="aurea-collection-feature__heading">{{ section.settings.heading }}</h2>
  </div>

  <div class="aurea-collection-feature__grid">
    {% if section.settings.collection != blank %}
      {% for product in section.settings.collection.products limit: 3 %}
        {% render 'card-product', product: product, eager: forloop.index <= 3 %}
      {% endfor %}
    {% endif %}
  </div>

  <div class="aurea-collection-feature__cta-wrap">
    <a href="{{ section.settings.collection.url | default: '/collections/all' }}" class="aurea-btn aurea-btn--ghost">View All</a>
  </div>
</section>

{% stylesheet %}
  .aurea-collection-feature {
    background: #1A1F1C;
    padding: 96px 64px 80px;
  }
  .aurea-collection-feature__header {
    text-align: center;
    margin-bottom: 56px;
  }
  .aurea-collection-feature__rule {
    width: 40px;
    height: 1px;
    background: #C5A96B;
    margin: 0 auto 20px;
  }
  .aurea-collection-feature__overline {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 10px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: #C5A96B;
    margin-bottom: 14px;
  }
  .aurea-collection-feature__heading {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 42px;
    font-weight: 300;
    font-style: italic;
    color: #F5F0E8;
    letter-spacing: 0.04em;
  }
  .aurea-collection-feature__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }
  .aurea-collection-feature__cta-wrap {
    text-align: center;
    margin-top: 48px;
  }

  @media (max-width: 1024px) {
    .aurea-collection-feature__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .aurea-collection-feature {
      padding: 64px 24px 56px;
    }
    .aurea-collection-feature__grid { grid-template-columns: 1fr; }
    .aurea-collection-feature__heading { font-size: 34px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection Feature",
  "settings": [
    {
      "type": "text",
      "id": "overline",
      "label": "Overline",
      "default": "Signature Fragrances"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    }
  ],
  "presets": [
    {
      "name": "Collection Feature"
    }
  ]
}
{% endschema %}
